{
  "llm": {
    "api_key": "",
    "api_base": "https://api.openai.com/v1",
    "model": "gpt-3.5-turbo",
    "max_tokens": 1000,
    "temperature": 0.7,
    "timeout": 30,
    "retry_attempts": 3,
    "retry_delay": 1.0
  },
  "sandbox": {
    "timeout": 5,
    "max_memory_mb": 256,
    "max_cpu_percent": 50,
    "allow_network": false,
    "allowed_imports": [
      "math",
      "random",
      "datetime",
      "collections",
      "itertools",
      "functools",
      "re",
      "json",
      "typing",
      "dataclasses"
    ],
    "blocked_imports": [
      "os",
      "sys",
      "subprocess",
      "socket",
      "http",
      "urllib",
      "pickle",
      "marshal",
      "ctypes",
      "importlib"
    ]
  },
  "debug": {
    "max_attempts": 5,
    "use_cache": true,
    "cache_size": 1000,
    "enable_local_fix": true,
    "enable_context_compression": true,
    "log_level": "INFO",
    "log_file": null
  }
}